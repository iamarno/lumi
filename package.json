{
  "name": "lumi",
  "version": "2.0.0",
  "description": "Lumi — a friendly, modular Matrix bot in TypeScript",
  "main": "dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "lumi": "./dist/lumi.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc",
    "start": "node dist/lumi.js",
    "dev": "ts-node src/lumi.ts",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:ci": "jest --ci",
    "prepare": "npm run build"
  },
  "dependencies": {
    "dotenv": "^17.0.0",
    "fake-indexeddb": "^6.0.0",
    "matrix-js-sdk": "^41.4.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "audit-ci": "^7.1.0",
    "jest": "^30.0.0",
    "jest-junit": "^17.0.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
