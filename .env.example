# ── Matrix (required) ─────────────────────────────────────────────────────────
MATRIX_HOMESERVER=https://matrix.org
MATRIX_USER_ID=@mybot:matrix.org
MATRIX_ACCESS_TOKEN=

# ── E2EE (optional) ───────────────────────────────────────────────────────────
#MATRIX_E2EE=true
#MATRIX_CRYPTO_PASSWORD=change-me
#MATRIX_PASSWORD=
#MATRIX_DEVICE_ID=
#MATRIX_CRYPTO_SAVE_INTERVAL=60

# ── Feature modules (optional) ────────────────────────────────────────────────
# Comma-separated directories of compiled feature modules (lumi_modules repo).
# Unset = core-only bot. Module env vars are documented in lumi_modules.
#LUMI_MODULES_DIR=../lumi_modules/dist

# ── Access control ────────────────────────────────────────────────────────────
#LUMI_ALLOWED_USERS=@alice:matrix.org,@bob:matrix.org
#LUMI_ALLOWED_ROOMS=!room1:matrix.org
#LUMI_ADMIN_ROOM=
# Admins may run privileged commands (!lumi reload, verify confirm/cancel, log-level changes).
# Unset: allowlisted users are admins; if there's no allowlist either, privileged commands are
# disabled (fail closed). Admins always bypass LUMI_ALLOWED_USERS.
#LUMI_ADMIN_USERS=@alice:matrix.org
#LUMI_ALLOW_ENV_RELOAD=false

# ── Runtime ───────────────────────────────────────────────────────────────────
#LUMI_STATE_DIR=./lumi-data
#METRICS_PORT=9091
#LOG_LEVEL=info
